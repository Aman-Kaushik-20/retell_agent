# ─── Retell ──────────────────────────────────────────────────────────────────
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxx
RETELL_BASE_URL=https://api.retellai.com
# Optional default for POST /calls. If unset, request body must supply from_number.
RETELL_FROM_NUMBER=+14157774444

# ─── Slack ───────────────────────────────────────────────────────────────────
# Provider enabled when both BOT_TOKEN and ALERT_CHANNEL are set.
SLACK_BOT_TOKEN=xoxb-xxxxxxxx-xxxxxxxx-xxxxxxxx
SLACK_BASE_URL=https://slack.com/api
SLACK_ALERT_CHANNEL=alerts

# ─── Discord ─────────────────────────────────────────────────────────────────
# Provider enabled when WEBHOOK_URL is set.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/<id>/<token>

# ─── Mattermost ──────────────────────────────────────────────────────────────
# Provider enabled when WEBHOOK_URL is set. Slack-compatible payload shape.
MATTERMOST_WEBHOOK_URL=https://<workspace>.cloud.mattermost.com/hooks/<hash>

# ─── ClickUp ─────────────────────────────────────────────────────────────────
# Provider enabled when both API_TOKEN and TASK_ID are set.
# Posts a comment on the configured task whenever a Retell event fires.
CLICKUP_API_TOKEN=pk_xxxxxxxx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLICKUP_TASK_ID=86d2w7fxf
